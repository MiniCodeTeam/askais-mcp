{
  "name": "askais-mcp",
  "version": "1.0.0",
  "description": "Remote MCP server for the AskAIs AI Receipt Generator API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "askais-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "server.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-receipt-generator",
    "receipt-api",
    "pdf-api",
    "cursor",
    "claude-code",
    "codex",
    "gemini"
  ],
  "author": "MiniCode LLC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MiniCodeTeam/askais-mcp.git"
  },
  "homepage": "https://askais.com/en/developers",
  "bugs": {
    "url": "https://github.com/MiniCodeTeam/askais-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "@hono/node-server": "^2.0.11"
  }
}
